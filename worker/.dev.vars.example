# Cloudflare Workers Development Variables
# Copy this file to .dev.vars and fill in the values

# Secrets (use wrangler secret put for production)
# API_SECRET_KEY=your-secret-key

# MongoDB Atlas — connection string for document storage alongside D1
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/nhimbe?retryWrites=true&w=majority

# Stytch — only the project ID is needed (no secret required).
# Auth is handled entirely by the Stytch frontend SDK.
# The backend validates session JWTs locally via Stytch's public JWKS.
STYTCH_PROJECT_ID=project-live-86090362-2491-4ca7-9037-f7688c7699ce
